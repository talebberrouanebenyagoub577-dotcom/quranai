# Sahra AI — copy to .env and adjust for your VPS

SAHRA_ENV=production
SAHRA_HOST=0.0.0.0
SAHRA_PORT=5000
SAHRA_DEBUG=false
SAHRA_LOG_LEVEL=INFO
SAHRA_BEHIND_PROXY=false
SAHRA_BACKUP_ON_STARTUP=true
SAHRA_BACKUP_MAX_KEEP=30
SAHRA_GUNICORN_WORKERS=2

OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
EMBED_MODEL=nomic-embed-text

# Optional absolute paths (defaults to project directory)
# SAHRA_MEMORY_FILE=/opt/sahra/quran_memory.json
# SAHRA_BRAIN_MEMORY_FILE=/opt/sahra/brain_memory.json
# SAHRA_PRODUCT_MEMORY_FILE=/opt/sahra/product_memory.json
# SAHRA_CONVERSATIONS_FILE=/opt/sahra/conversations.json
# SAHRA_LOG_DIR=/opt/sahra/logs
# SAHRA_BACKUP_DIR=/opt/sahra/backups
